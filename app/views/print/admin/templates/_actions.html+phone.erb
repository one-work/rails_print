<%= button_to({ controller: 'template_tasks', action: 'new', template_id: model.id }, class: 'cell has-column-centered') do %>
  <%= svg_tag 'plus' %>
  <span><%= t('.template_tasks.new.title') %></span>
<% end %>
<%= button_to({ action: 'edit' }, class: 'cell has-column-centered') do %>
  <%= svg_tag 'pencil' %>
  <span><%= t('.edit.title') %></span>
<% end %>
<%= link_to({ action: 'show' }, class: 'cell has-column-centered') do %>
  <%= svg_tag 'circle-info' %>
  <span><%= t('.show.title') %></span>
<% end %>
