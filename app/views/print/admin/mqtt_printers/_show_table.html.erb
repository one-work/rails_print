<div>
  <dt>打印任务 URL：</dt>
  <dd data-controller="clipboard">
    <div class="text-left">
      <span data-clipboard-target="source" class="is-wrap"><%= @mqtt_printer.webhook_url %></span>
    </div>
    <div data-action="click->clipboard#copy" class="tag is-badge is-danger">复制</div>
    <div data-clipboard-target="toast" class="tag is-badge is-success display-none">
      <%= svg_tag 'check' %>
    </div>
  </dd>
</div>