<td class="family-monospace">
  <p><%= model.dev_imei %></p>
  <p><time data-controller="time"><%= model.created_at.to_fs(:iso8601) %></time></p>
</td>
<td>
  <p>
  <% if model.registered_at.present? %>
    <time data-controller="time"><%= model.registered_at.to_fs(:iso8601) %></time>
  <% end %>
  </p>
  <p class="text-success">
  <% if model.authorized_at.present? %>
    <time data-controller="time"><%= model.authorized_at.to_fs(:iso8601) %></time>
  <% end %>
  </p>
</td>
<td><%= model.dev_desc %></td>
<td>
  <% if model.online %>
    <p>
      <div class="tags has-addons">
        <span class="tag">在线</span>
        <%= svg_tag 'check' %>
      </div>
    </p>
  <% elsif model.offline_at %>
    <p>
      <span class="text-grey"><%= Print::MqttPrinter.human_attribute_name(:offline_at) %></span>
      <time data-controller="time"><%= model.offline_at.to_fs(:iso8601) %></time>
    </p>
  <% end %>
</td>
<td>
  <p><%= model.organ.name if model.organ %></p>
  <p>
    <%= button_to({ action: 'organ', id: model.id }) do %>
      <%= svg_tag 'pencil' %>
    <% end %>
  </p>
</td>
<td>
  <p><%= model.username %></p>
  <p><%= model.password %></p>
</td>